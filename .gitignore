# Log files
*.log

# Brewfile lock can be different in multiple systems
Brewfile.lock.json

# Build source scripts
shell/source/*

# Zsh completions regenerated by tools/*/configure.sh (see ZSH_GENERATED_COMPLETIONS)
shell/zsh/completions/generated/*

# Always use gitkeep
!.gitkeep


### Python ###
.venv/
.pytest_cache/
# Byte-compiled / optimized / DLL files
__pycache__/
*.py[cod]
*$py.class
