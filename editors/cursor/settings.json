{
    "[dockercompose]": {
        "editor.autoIndent": "advanced",
        "editor.defaultFormatter": "redhat.vscode-yaml",
        "editor.insertSpaces": true,
        "editor.quickSuggestions": {
            "comments": false,
            "other": true,
            "strings": true
        },
        "editor.tabSize": 2
    },
    "[github-actions-workflow]": {
        "editor.defaultFormatter": "redhat.vscode-yaml"
    },
    "[html]": {
        "editor.defaultFormatter": "esbenp.prettier-vscode"
    },
    "[javascript]": {
        "editor.defaultFormatter": "esbenp.prettier-vscode"
    },
    "[json]": {
        "editor.defaultFormatter": "vscode.json-language-features",
        "editor.formatOnSave": false
    },
    "[jsonc]": {
        "editor.defaultFormatter": "vscode.json-language-features",
        "editor.formatOnSave": false
    },
    "[markdown]": {
        "editor.defaultFormatter": "esbenp.prettier-vscode",
        "editor.tabSize": 4
    },
    "[python]": {
        "editor.defaultFormatter": "charliermarsh.ruff",
        "editor.semanticHighlighting.enabled": false
    },
    "[toml]": {
        "editor.defaultFormatter": "be5invis.toml"
    },
    "[typescript]": {
        "editor.defaultFormatter": "esbenp.prettier-vscode"
    },
    "[typescriptreact]": {
        "editor.defaultFormatter": "esbenp.prettier-vscode"
    },
    "[yaml]": {
        "diffEditor.ignoreTrimWhitespace": false,
        "editor.defaultFormatter": "esbenp.prettier-vscode"
    },
    "accessibility.signalOptions.volume": 100,
    "autoDocstring.docstringFormat": "google",
    "aws.telemetry": false,
    "breadcrumbs.enabled": true,
    "claudeCode.preferredLocation": "panel",
    "cSpell.enabled": true,
    "cSpell.spellCheckOnlyWorkspaceFiles": true,
    "cursor.composer.shouldChimeAfterChatFinishes": true,
    "cursor.composer.usageSummaryDisplay": "always",
    "diffEditor.experimental.showMoves": true,
    "diffEditor.hideUnchangedRegions.enabled": true,
    "diffEditor.ignoreTrimWhitespace": false,
    "diffEditor.renderSideBySide": true,
    "docker.extension.enableComposeLanguageServer": false,
    "editor.acceptSuggestionOnEnter": "on",
    "editor.accessibilitySupport": "on",
    "editor.codeActionsOnSave": {
        "source.fixAll.eslint": "explicit"
    },
    "editor.cursorBlinking": "phase",
    "editor.fontFamily": "MesloLGLDZ Nerd Font Mono",
    "editor.fontLigatures": false,
    "editor.fontSize": 12,
    "editor.formatOnSave": true,
    "editor.inlineSuggest.edits.showCollapsed": true,
    "editor.inlineSuggest.enabled": true,
    "editor.minimap.enabled": false,
    "editor.renderWhitespace": "boundary",
    "editor.rulers": [
        80,
        120
    ],
    "editor.smoothScrolling": true,
    "editor.snippetSuggestions": "top",
    "editor.suggest.preview": true,
    "editor.suggest.showMethods": true,
    "editor.suggestSelection": "first",
    "editor.tabCompletion": "on",
    "editor.tabSize": 4,
    "editor.trimAutoWhitespace": true,
    "eslint.format.enable": false,
    "evenBetterToml.formatter.alignEntries": false,
    "explorer.confirmDelete": false,
    "explorer.confirmDragAndDrop": false,
    "explorer.openEditors.visible": 0,
    "extensions.autoUpdate": true,
    "extensions.ignoreRecommendations": true,
    "files.associations": {
        ".coveragerc": "toml",
        ".env.*": "dotenv",
        ".gitconfig.*": "properties",
        "*.hcl": "terraform",
        "*.hql": "sql",
        "*.j2": "jinja",
        "*.jsonl": "json",
        "*.tmpl": "gotemplate",
        "*.yml": "yaml"
    },
    "files.autoSave": "onFocusChange",
    "files.exclude": {
        "**/.classpath": true,
        "**/.factorypath": true,
        "**/.project": true,
        "**/.settings": true
    },
    "files.insertFinalNewline": true,
    "files.trimFinalNewlines": true,
    "files.trimTrailingWhitespace": true,
    "files.watcherExclude": {
        "**/.ammonite": true,
        "**/.bloop": true,
        "**/.metals": true
    },
    "git.allowForcePush": true,
    "git.autofetch": true,
    "git.confirmForcePush": false,
    "git.confirmSync": false,
    "git.ignoreRebaseWarning": true,
    "git.replaceTagsWhenPull": true,
    "git.suggestSmartCommit": false,
    "git.terminalAuthentication": false,
    "githubPullRequests.notifications": "pullRequests",
    "githubPullRequests.pullBranch": "never",
    "githubPullRequests.queries": [
        {
            "label": "Review Requests",
            "query": "repo:${owner}/${repository} is:open review-requested:${user}"
        },
        {
            "label": "My PRs",
            "query": "repo:${owner}/${repository} is:open author:${user}"
        }
    ],
    "gitlab.duoAgentPlatform.enabled": false,
    "gitlab.duoChat.enabled": false,
    "gitlab.duoCodeSuggestions.enabled": false,
    "gitlens.codeLens.scopes": [
        "document",
        "containers"
    ],
    "gitlens.gitkraken.mcp.autoEnabled": false,
    "gitlens.graph.dateStyle": "absolute",
    "gitlens.graph.highlightRowsOnRefHover": false,
    "gitlens.graph.minimap.enabled": false,
    "gitlens.graph.scrollMarkers.additionalTypes": [
        "localBranches",
        "stashes",
        "remoteBranches",
        "pullRequests"
    ],
    "gitlens.graph.showDetailsView": false,
    "gitlens.hovers.annotations.enabled": false,
    "gitlens.hovers.annotations.over": "annotation",
    "gitlens.hovers.currentLine.changes": false,
    "gitlens.hovers.currentLine.enabled": false,
    "gitlens.hovers.currentLine.over": "line",
    "gitlens.hovers.enabled": false,
    "gitlens.views.commitDetails.files.layout": "tree",
    "gitlens.views.formats.commits.tooltip": "", // This disable the over of the commits in the graph
    "gitlens.views.launchpad.files.layout": "tree",
    "gitlens.views.repositories.showBranches": false,
    "gitlens.views.repositories.showCommits": false,
    "gitlens.views.repositories.showContributors": false,
    "gitlens.views.repositories.showRemotes": false,
    "gitlens.views.repositories.showTags": false,
    "go.buildFlags": [
        "-v"
    ],
    "go.coverageDecorator": {
        "type": "gutter"
    },
    "go.coverOnSingleTest": true,
    "go.formatTool": "goimports",
    "go.testTimeout": "3m",
    "go.toolsManagement.autoUpdate": true,
    "go.useLanguageServer": true,
    "html.format.wrapLineLength": 0,
    "javascript.format.placeOpenBraceOnNewLineForControlBlocks": true,
    "javascript.updateImportsOnFileMove.enabled": "always",
    "jest.runMode": "on-demand",
    "json.schemaDownload.enable": true,
    "jupyter.askForKernelRestart": false,
    "jupyter.disableJupyterAutoStart": true,
    "jupyter.widgetScriptSources": [
        "jsdelivr.com",
        "unpkg.com"
    ],
    "markdown.extension.list.indentationSize": "inherit",
    "markdownlint.config": {
        "MD007": false,
        "MD024": false,
        "MD033": false
    },
    "mise.updateEnvAutomaticallyIncludePath": true,
    "notebook.cellExecutionTimeVerbosity": "verbose",
    "notebook.cellToolbarLocation": {
        "default": "right",
        "jupyter-notebook": "left"
    },
    "notebook.lineNumbers": "on",
    "notebook.output.minimalErrorRendering": true,
    "notebook.output.scrolling": true,
    "notebook.output.textLineLimit": 500,
    "peacock.favoriteColors": [
        {
            "name": "Catppuccin Mocha Mauve",
            "value": "#cba6f7"
        },
        {
            "name": "Catppuccin Mocha Red",
            "value": "#f38ba8"
        },
        {
            "name": "Catppuccin Mocha Maroon",
            "value": "#eba0ac"
        },
        {
            "name": "Catppuccin Mocha Peach",
            "value": "#fab387"
        },
        {
            "name": "Catppuccin Mocha Green",
            "value": "#a6e3a1"
        },
        {
            "name": "Catppuccin Mocha Teal",
            "value": "#94e2d5"
        },
        {
            "name": "Catppuccin Mocha Saphire",
            "value": "#74c7ec"
        },
        {
            "name": "Catppuccin Mocha Blue",
            "value": "#89b4fa"
        },
        {
            "name": "Catppuccin Mocha Lavender",
            "value": "#b4befe"
        },
        {
            "name": "Catppuccin Mocha Crust",
            "value": "#11111b"
        },
        {
            "name": "Cattpuccin Mocha Crust (Darken)",
            "value": "#07070b"
        }
    ],
    "python.testing.pytestEnabled": true,
    "redhat.telemetry.enabled": false,
    "rest-client.enableTelemetry": false,
    "scm.defaultViewMode": "tree",
    "scm.providerCountBadge": "visible",
    "scm.workingSets.enabled": true,
    "search.exclude": {
        "**/bower_components": true,
        "**/node_modules": true,
        "/.venv": true,
        "/vendor": true
    },
    "search.showLineNumbers": true,
    "search.smartCase": true,
    "search.useGlobalIgnoreFiles": true,
    "security.workspace.trust.untrustedFiles": "open",
    "shellcheck.customArgs": [
        "-x"
    ],
    "shfmt.formatIgnored": false,
    "snowflake.connectionsConfigFile": "/Users/pablosanjose/.snowflake/connections.toml",
    "sonarlint.focusOnNewCode": true,
    "sonarlint.ls.javaHome": "/usr/local/lib/jvm/java/openjdk-19",
    "sqltools.connections": [],
    "sqltools.format": {
        "reservedWordCase": "upper"
    },
    "sqltools.highlightQuery": false,
    "sqltools.useNodeRuntime": true,
    "terminal.external.osxExec": "ghostty",
    "terminal.integrated.cursorBlinking": true,
    "terminal.integrated.defaultProfile.osx": "zsh",
    "terminal.integrated.fontSize": 12,
    "terminal.integrated.inheritEnv": false,
    "testing.coverageToolbarEnabled": true,
    "todo-tree.filtering.excludeGlobs": [
        "**/_build/**",
        "**/htmlcov/**"
    ],
    "todo-tree.filtering.ignoreGitSubmodules": true,
    "todo-tree.general.statusBar": "total",
    "typescript.updateImportsOnFileMove.enabled": "always",
    "window.newWindowDimensions": "maximized",
    "window.restoreWindows": "one",
    "window.title": "${activeEditorMedium}${separator}${rootName}",
    "workbench.colorTheme": "Catppuccin Mocha",
    "workbench.editor.highlightModifiedTabs": true,
    "workbench.editor.showIcons": true,
    "workbench.editorAssociations": {
        "{git,gitlens,conflictResolution,vscode-local-history}:/**/*.{asl.json,asl.yaml,asl.yml}": "default",
        "{git,gitlens,conflictResolution,vscode-local-history}:/**/*.tc.json": "default",
        "*.csv": "duckdb.dataFileViewer",
        "*.ipynb": "jupyter-notebook",
        "*.parquet": "duckdb.dataFileViewer",
        "*.tsv": "duckdb.dataFileViewer",
        "git-rebase-todo": "default"
    },
    "workbench.fontAliasing": "auto",
    "workbench.iconTheme": "catppuccin-mocha"
}
