{
    "version": 1,
    "editor": {
        "vimMode": false
    },
    "attribution": {
        "attributeCommitsToAgent": false,
        "attributePRsToAgent": false
    },
    "permissions": {
        "allow": [
            "Read(**)",
            "Write(**)",
            "WebFetch(github.com)",
            "WebFetch(*.github.com)",
            "WebFetch(npmjs.com)",
            "WebFetch(*.npmjs.com)",
            "WebSearch(*)",
            "WebSearch(*)",
            "Mcp(figma:*)",
            "Mcp(plugin_figma_figma:*)",
            "Shell(aws)",
            "Shell(basename)",
            "Shell(bun)",
            "Shell(cat)",
            "Shell(cut)",
            "Shell(date)",
            "Shell(diff)",
            "Shell(dirname)",
            "Shell(echo)",
            "Shell(file)",
            "Shell(find)",
            "Shell(gh)",
            "Shell(git:add*)",
            "Shell(git:blame*)",
            "Shell(git:cat-file*)",
            "Shell(git:commit*)",
            "Shell(git:config --get*)",
            "Shell(git:config --list*)",
            "Shell(git:diff*)",
            "Shell(git:fetch*)",
            "Shell(git:grep*)",
            "Shell(git:log*)",
            "Shell(git:ls-files*)",
            "Shell(git:ls-remote*)",
            "Shell(git:ls-tree*)",
            "Shell(git:merge-base*)",
            "Shell(git:remote -v*)",
            "Shell(git:remote get-url*)",
            "Shell(git:remote show*)",
            "Shell(git:rev-list*)",
            "Shell(git:rev-parse*)",
            "Shell(git:show*)",
            "Shell(git:status*)",
            "Shell(git:symbolic-ref*)",
            "Shell(git:worktree list*)",
            "Shell(glab)",
            "Shell(grep)",
            "Shell(head)",
            "Shell(jq)",
            "Shell(ls)",
            "Shell(make)",
            "Shell(mkdir)",
            "Shell(mise)",
            "Shell(npm)",
            "Shell(pip)",
            "Shell(pnpm)",
            "Shell(poetry)",
            "Shell(pytest)",
            "Shell(python:-m json.tool*)",
            "Shell(python3:-m json.tool*)",
            "Shell(readlink)",
            "Shell(realpath)",
            "Shell(ripgrep)",
            "Shell(rg)",
            "Shell(rtk)",
            "Shell(sort)",
            "Shell(stat)",
            "Shell(tail)",
            "Shell(touch)",
            "Shell(tr)",
            "Shell(uname)",
            "Shell(uniq)",
            "Shell(vitest)",
            "Shell(wc)",
            "Shell(which)",
            "Shell(yarn)"
        ],
        "deny": [
            "Read(.env*)",
            "Read(**/.env)",
            "Read(**/.env.*)",
            "Read(**/*.pem)",
            "Read(**/id_ed25519)",
            "Read(**/id_rsa)",
            "Write(.env*)",
            "Write(**/.env)",
            "Write(**/.env.*)",
            "Write(**/*.pem)",
            "Write(**/id_ed25519)",
            "Write(**/id_rsa)"
        ]
    }
}
