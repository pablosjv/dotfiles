#!/usr/bin/env bash
#
# dot
#
# brew wrapper
#
# Note: All brew commands use 'command brew' instead of just 'brew' to bypass
# any aliases or functions that might be defined. This is critical since this
# script is a wrapper that may be aliased as 'brew' itself, and using 'command'
# ensures we always call the actual Homebrew executable, preventing infinite
# recursion.

log-info() {
    # shellcheck disable=SC2059
    printf "\r  [ \033[00;34m..\033[0m ] $1\n"
}

brew-bump() {
    log-info "Bumping homebrew... $1"
    command brew update
    command brew outdated | xargs command brew fetch
    command brew bundle install --verbose --global
    command brew upgrade
    log-info "Upgrade casks (you can pass --greedy to force update)..."
    # shellcheck disable=SC2086
    command brew upgrade --cask ${1}
    command brew cleanup
}

brew-cleanup() {
    log-info "Cleanup homebrew..."
    (cd "$(command brew --repo)" && git prune && git gc)
    command brew bundle cleanup --global --force --zap
    command brew cleanup --prune=all
    rm -rf "$(command brew --cache)"
}

brew-repair() {
    log-info "Try to repair homebrew..."
    (cd "$(command brew --repo)" && git fetch && git reset --hard origin/master)
    command brew update
}

brew-bundle-clean() {
    local brewfile="${HOMEBREW_BUNDLE_FILE_GLOBAL:-$HOME/.Brewfile}"
    local real_brewfile
    local explicit_list

    if [ -L "$brewfile" ]; then
        local target
        target=$(readlink "$brewfile")
        case "$target" in
        /*) real_brewfile="$target" ;;
        *) real_brewfile="$(cd "$(dirname "$brewfile")" && cd "$(dirname "$target")" && pwd)/$(basename "$target")" ;;
        esac
    else
        real_brewfile="$brewfile"
    fi

    log-info "Filtering Brewfile to top-level formulae only (brew leaves --installed-on-request)"
    explicit_list=$(mktemp)
    command brew leaves --installed-on-request 2>/dev/null | sort -u >"$explicit_list"
    awk '
        NR==FNR { explicit[$1]=1; next }
        /^#/ { comment=comment $0 "\n"; next }
        /^brew "/ {
            name=$0
            sub(/^brew "/, "", name)
            sub(/".*$/, "", name)
            if (name in explicit) { printf "%s%s", comment, $0 "\n" }
            comment=""
            next
        }
        { printf "%s%s", comment, $0 "\n"; comment=""; next }
        END { if (comment != "") printf "%s", comment }
    ' "$explicit_list" "$brewfile" >"${real_brewfile}.tmp" && mv "${real_brewfile}.tmp" "$real_brewfile"
    rm -f "$explicit_list"
}

case "$1" in
cleanup)
    brew-cleanup
    ;;
bump)
    brew-bump "$2"
    ;;
repair)
    brew-repair
    ;;
bundle-clean)
    brew-bundle-clean
    ;;
*)
    command brew "$@"
    ;;
esac
